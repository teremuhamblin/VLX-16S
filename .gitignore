########################################
#   GITKEEP RULES (si tu veux garder les dossiers)
########################################

# Ignorer tout sauf .gitkeep dans certains dossiers
logs/*
!logs/.gitkeep

cache/*
!cache/.gitkeep

tmp/*
!tmp/.gitkeep

data/*
!data/.gitkeep
